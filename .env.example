# ============================================
# ViralHub — Variáveis de Ambiente
# ============================================
# Em produção, configure diretamente no painel da plataforma (Railway / Vercel).
# Localmente, copie para os locais corretos:
#
#   cp .env.example .env                   (raiz — GEMINI_API_KEY)
#   cp .env.example execution/.env         (backend)
#   cp .env.example web-app/.env           (frontend)
#
# NUNCA commite arquivos .env com valores reais.

# ── Backend (execution/.env | Railway) ───────

# IMPORTANTE: Em produção (Railway), use o Supabase POOLER (Session mode, porta 5432):
#   postgresql+asyncpg://postgres.SEU_PROJECT_REF:SENHA@aws-0-REGIAO.pooler.supabase.com:5432/postgres
#
# Localmente, pode usar conexão direta:
#   postgresql+asyncpg://postgres:SENHA@db.SEU_PROJECT_REF.supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres.SEU_PROJECT_REF:SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
GEMINI_API_KEY=

# Origens CORS permitidas (separadas por virgula). Use * para dev local.
# Em produção: https://seu-app.vercel.app
CORS_ORIGINS=*

# ── Frontend (web-app/.env | Vercel) ────────
VITE_API_URL=http://localhost:8000
VITE_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=<anon/public key do Supabase Dashboard>
