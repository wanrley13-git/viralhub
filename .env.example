# ============================================
# ViralHub — Variáveis de Ambiente
# ============================================
# Copie este arquivo para os locais corretos e preencha os valores.
#
#   cp .env.example .env                   (raiz — GEMINI_API_KEY)
#   cp .env.example execution/.env         (backend — DATABASE_URL, SUPABASE_URL)
#   cp .env.example web-app/.env           (frontend — VITE_*)
#
# NUNCA commite arquivos .env com valores reais.

# ── Backend (execution/.env) ─────────────────
# Postgres via Supabase
DATABASE_URL=postgresql+asyncpg://postgres:SENHA@db.SEU_PROJECT_REF.supabase.co:5432/postgres

# URL do projeto Supabase (para validação JWKS)
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co

# ── Raiz (.env) ──────────────────────────────
# Google Gemini API
GEMINI_API_KEY=

# ── Frontend (web-app/.env) ──────────────────
VITE_API_URL=http://localhost:8000
VITE_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=<anon/public key do Supabase Dashboard>
